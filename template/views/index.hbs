<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="css/style.css" />
    <title>Weather</title>
  </head>
  <body>
    <div
      class="bg-[url('/images/background.jpg')] bg-cover bg-center h-screen w-full flex justify-center items-center"
    >
      <div
        class="backdrop-blur-sm w-fit py-8 px-10 rounded-2xl border border-white/20 shadow-2xl text-center"
      >
        <div class="flex items-center justify-center gap-3 mb-4">
          <img
            src="/images/weatherIcon.png"
            alt="Weather Icon"
            class="size-14 drop-shadow-md white-icon"
          />

          <h1
            class="text-3xl font-extrabold text-white/90 drop-shadow-md tracking-wide"
          >
            Weather App
          </h1>
        </div>
        <form class="flex flex-col items-center space-y-4" id="form1">
          <input
            placeholder="Enter location..."
            class="bg-white/90 text-slate-900 placeholder-slate-400 outline:none rounded-lg px-2 py-2 focus:outline-none focus:shadow-amber-200 focus:shadow-[0_0_10px_rgba(6,182,212,0.5)]"
            type="text"
            id="countryInput"
          />
          <button
            id="submit-btn"
            class="w-fit px-4 py-4 flex justify-center items-center gap-2 bg-slate-800/80 hover:bg-slate-900 text-white font-semibold rounded-xl transition-colors duration-500 backdrop-blur-sm disabled:opacity-50 disabled:cursor-not-allowed"
          ><span id="btn-text">Get Weather</span>

            <svg
              id="btn-spinner"
              class="hidden animate-spin h-5 w-5 text-white"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"
              ></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              ></path>
            </svg></button>
        </form>
        <div
          id="errorContainer"
          class="hidden mt-6 w-full flex items-center gap-3 bg-red-500/20 backdrop-blur-md border border-red-500/30 rounded-2xl px-5 py-4 shadow-lg"
        >
          <svg
            class="w-6 h-6 text-red-400 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            />
          </svg>
          <p id="error" class="text-white text-sm font-medium"></p>
        </div>

        <div
          id="dataContainer"
          class="hidden mt-8 w-full flex-col gap-4 space-y-4"
        >

          <div class="flex justify-center w-full mb-2">
            <img
              id="weather-icon"
              src=""
              alt="Weather Condition"
              class="hidden w-20 h-20 drop-shadow-xl"
            />
          </div>

          <div
            class="flex items-center gap-4 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl px-5 py-4 w-full shadow-lg transition-all hover:bg-white/20"
          >
            <svg
              class="w-6 h-6 text-slate-900 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
                clip-rule="evenodd"
              />
            </svg>
            <p class="text-white text-sm tracking-wide">
              <span class="text-white/70">Country:</span>
              <span id="location" class="font-semibold ml-1"></span>
            </p>
          </div>

          <div
            class="flex items-center gap-4 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl px-5 py-4 w-full shadow-lg transition-all hover:bg-white/20"
          >
            <svg
              class="w-6 h-6 text-slate-900 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
              />
            </svg>
            <p class="text-white text-sm tracking-wide">
              <span class="text-white/70">Latitude:</span>
              <span id="lat" class="font-semibold ml-1"></span>
            </p>
          </div>

          <div
            class="flex items-center gap-4 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl px-5 py-4 w-full shadow-lg transition-all hover:bg-white/20"
          >
            <svg
              class="w-6 h-6 text-slate-900 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
              />
            </svg>
            <p class="text-white text-sm tracking-wide">
              <span class="text-white/70">Longitude:</span>
              <span id="lon" class="font-semibold ml-1"></span>
            </p>
          </div>

          <div
            class="flex items-center gap-4 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl px-5 py-4 w-full shadow-lg transition-all hover:bg-white/20"
          >
            <svg
              class="w-6 h-6 text-slate-900 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"
              />
            </svg>
            <p class="text-white text-sm tracking-wide">
              <span class="text-white/70">Temperature:</span>
              <span id="temp" class="font-semibold ml-1"></span>
              <span class="text-white/70">°C</span>
            </p>
          </div>

        </div>
      </div>
    </div>
    <script src="js/script.js"></script>
  </body>
</html>